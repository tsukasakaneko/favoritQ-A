# ----- Database -----
POSTGRES_USER=favoritq
POSTGRES_PASSWORD=favoritq_pass
POSTGRES_DB=favoritq
# Connection string used by the backend (host "db" is the compose service name)
DATABASE_URL=postgres://favoritq:favoritq_pass@db:5432/favoritq

# ----- Backend -----
BACKEND_PORT=5000
# Comma-free origin allowed for CORS / Socket.IO (the Vite dev server)
CLIENT_ORIGIN=http://localhost:5173

# ----- AI (optional) -----
# If set, お題の選択肢を Claude で生成します。未設定ならモックの選択肢を返します。
# https://console.anthropic.com/ で取得したキーを入れてください（ダミー値のままでも動作します）
ANTHROPIC_API_KEY=

# ----- Frontend -----
# ブラウザから見たバックエンドのURL（ホスト側のポート）
VITE_API_BASE=http://localhost:5000
